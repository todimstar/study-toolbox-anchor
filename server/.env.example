HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./toolbox.db

# Micro chat
# Parent key should not be embedded in the child-facing page. Enter it on the parent device.
PARENT_CHAT_KEY=change-parent-chat-key
# Child key is currently embedded in toolbox-site/index.html for the child-side sender.
CHILD_CHAT_KEY=child-chat-key-change-me
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=20971520
